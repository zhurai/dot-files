set $ws-game1 5

# Genymotion Player
for_window [title="^(?!Genymotion$)" class="Genymotion Player"] move container to workspace $ws-game1
for_window [title="^(?!Genymotion$)" class="Genymotion Player"] layout tabbed

# Waydroid (Epic Seven)
for_window [app_id="Waydroid"] move container to workspace $ws-game1
for_window [app_id="Waydroid"] layout tabbed
for_window [app_id="waydroid.com.stove.epic7.google"] move container to workspace $ws-game1
for_window [app_id="waydroid.com.stove.epic7.google"] layout tabbed

# Lutris/Wine - Counter Side
for_window [class="counterside.exe"] move container to workspace $ws-game1
for_window [class="counterside.exe"] layout tabbed

# Vysor
for_window [title="^(?!.*Vysor.*$)" class="vysor"] move container to workspace $ws-game1
for_window [title="^(?!.*Vysor.*$)" class="vysor"] layout tabbed
for_window [title="^(?!.*Vysor.*$)" class="vysor"] floating disable

# Scrcpy
for_window [app_id="scrcpy"] move container to workspace $ws-game1
for_window [app_id="scrcpy"] layout tabbed
for_window [app_id="scrcpy"] floating disable
