set $ws-game1 5

# Genymotion Player
for_window [class="Genymotion Player"] move container to workspace $ws-game1
for_window [class="Genymotion Player"] layout tabbed

# Waydroid (Epic Seven)
for_window [app_id="Waydroid"] move container to workspace $ws-game1
for_window [app_id="Waydroid"] layout tabbed
for_window [app_id="waydroid.com.stove.epic7.google"] move container to workspace $ws-game1
for_window [app_id="waydroid.com.stove.epic7.google"] layout tabbed
#for_window [app_id="Waydroid"] fullscreen

# Lutris/Wine - Counter Side
for_window [class="counterside.exe"] move container to workspace $ws-game1
for_window [class="counterside.exe"] layout tabbed

# Remote Desktop
for_window [title="^zHome-zServer001$" app_id="org.remmina.Remmina"] move container to workspace $ws-game1
for_window [title="^zHome-zServer001$" app_id="org.remmina.Remmina"] layout tabbed
for_window [title="^zHome-zServer001$" app_id="org.remmina.Remmina"] floating disable
for_window [title="^zHome-zServer001$" app_id="org.remmina.Remmina"] fullscreen disable

