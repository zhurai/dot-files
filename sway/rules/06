set $ws-games2 6

# Minecraft
for_window [class="Minecraft.*"] move container to workspace $ws-games2
for_window [class="Minecraft.*"] fullscreen disable

# Osu!
for_window [class="osu!.exe"] move container to workspace $ws-games2
for_window [title="osu!" class="dotnet"] move container to workspace $ws-games2

# Lutris Battle.net - StarCraft 2
for_window [class="sc2_x64.exe"] move container to workspace $ws-games2
for_window [class="sc2_x64.exe"] fullscreen enable

# Lutris Battle.net - StarCraft BW
for_window [class="starcraft.exe"] move container to workspace $ws-games2
for_window [class="starcraft.exe"] fullscreen enable

# Lutris - Guild Wars
for_window [class="gw.exe"] move container to workspace $ws-games2
for_window [class="gw.exe"] fullscreen enable

# Lutris - Guild Wars 2
for_window [class="gw2-64.exe"] move container to workspace $ws-games2
for_window [class="gw2-64.exe"] fullscreen enable

# Lutris - MTGO
for_window [class="mtgo.exe"] move container to workspace $ws-games2
for_window [class="mtgo.exe"] fullscreen enable

# Lutris - MTGA
for_window [class="mtga.exe"] move container to workspace $ws-games2
for_window [class="mtga.exe"] fullscreen enable

# All Steam Applications / Games
for_window [class="(steam_app_).*"] move container to workspace $ws-games2

# Steam - HoloCure Overrides
for_window [title="HoloCure" class="(steam_app_2420510)"] floating disable
for_window [title="HoloCure" class="(steam_app_2420510)"] resize set height 100
for_window [title="HoloCure" class="(steam_app_2420510)"] resize set width 100

