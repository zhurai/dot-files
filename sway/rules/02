set $ws-games-general 2

# Mahjong Soul
for_window [title="MahjongSoul - Chromium" class="chromium"] move container to workspace $ws-games-general

# Minecraft
for_window [class="Minecraft"] move container to workspace $ws-games-general
for_window [class="Minecraft"] fullscreen enable

# Osu!
for_window [class="osu!.exe"] move container to workspace $ws-games-general
for_window [class="osu!.exe"] layout stacking
for_window [class="osu!.exe"] fullscreen enable
for_window [title="osu!" class="dotnet"] move container to workspace $ws-games-general
for_window [title="osu!" class="dotnet"] layout stacking
for_window [title="osu!" class="dotnet"] fullscreen enable

# Lutris Battle.net - StarCraft 2
for_window [class="sc2_x64.exe"] move container to workspace $ws-games-general
for_window [class="sc2_x64.exe"] layout stacking
for_window [class="sc2_x64.exe"] fullscreen enable

# Lutris Battle.net - StarCraft BW
for_window [class="starcraft.exe"] move container to workspace $ws-games-general
for_window [class="starcraft.exe"] layout stacking
for_window [class="starcraft.exe"] fullscreen enable

# Lutris - Guild Wars
for_window [class="gw.exe"] move container to workspace $ws-games-general
for_window [class="gw.exe"] layout stacking
for_window [class="gw.exe"] fullscreen enable

# Lutris - Guild Wars 2
for_window [class="gw2-64.exe"] move container to workspace $ws-games-general
for_window [class="gw2-64.exe"] layout stacking
for_window [class="gw2-64.exe"] fullscreen enable

# Lutris - HRL - Honkai Star Rail
for_window [instance="starrail.exe"] move container to workspace $ws-games-general
for_window [instance="starrail.exe"] layout stacking
for_window [instance="starrail.exe"] fullscreen enable

# Lutris - AGL - Genshin Impact
for_window [instance="genshinimpact.exe"] move container to workspace $ws-games-general
for_window [instance="genshinimpact.exe"] layout stacking
for_window [instance="genshinimpact.exe"] fullscreen enable

# All Steam Applications / Games
for_window [class="(steam_app_).*"] move container to workspace $ws-games-general
for_window [class="(steam_app_).*"] layout stacking
for_window [class="(steam_app_).*"] fullscreen enable

# Steam - HoloCure Overrides
for_window [title="HoloCure" class="(steam_app_2420510)"] floating disable
for_window [title="HoloCure" class="(steam_app_2420510)"] resize set height 100
for_window [title="HoloCure" class="(steam_app_2420510)"] resize set width 100
