set $ws-support 8

# Steam
for_window [class="^(steam)$"] move container to workspace $ws-support
for_window [class="^(steam)$"] layout tabbed

# Prism Launcher
for_window [app_id="org.prismlauncher.PrismLauncher"] move container to workspace $ws-support
for_window [app_id="org.prismlauncher.PrismLauncher"] layout tabbed

# Genymotion
for_window [class="^Genymotion$"] move container to workspace $ws-support
for_window [class="^Genymotion$"] layout tabbed

# Lutris
for_window [app_id="lutris"] move container to workspace $ws-support
for_window [app_id="lutris"] layout tabbed

# Remmina
for_window [title="Remmina Remote Desktop Client" app_id="org.remmina.Remmina"] move container to workspace $ws-support
for_window [title="Remmina Remote Desktop Client" app_id="org.remmina.Remmina"] layout tabbed

# Battle.net
for_window [class="battle.net.exe"] move container to workspace $ws-support
for_window [class="battle.net.exe"] layout tabbed

# VirtualBox Manager
for_window [class="VirtualBox Manager"] move container to workspace $ws-support
for_window [class="VirtualBox Manager"] layout tabbed

# Itch.io
for_window [class="itch"] move container to workspace $ws-support
for_window [class="itch"] layout tabbed

# Remmina Client (TBD)
#for_window [title="^(?!Remmina Remote Desktop Client).*$" app_id="org.remmina.Remmina"] move container to workspace
for_window [title="^(?!Remmina Remote Desktop Client).*$" app_id="org.remmina.Remmina"] fullscreen disable
for_window [title="^(?!Remmina Remote Desktop Client).*$" app_id="org.remmina.Remmina"] floating enable
for_window [title="^(?!Remmina Remote Desktop Client).*$" app_id="org.remmina.Remmina" floating] resize set height 100 ppt
for_window [title="^(?!Remmina Remote Desktop Client).*$" app_id="org.remmina.Remmina" floating] resize set width 100 ppt
for_window [title="^(?!Remmina Remote Desktop Client).*$" app_id="org.remmina.Remmina" floating] move position 0 px 0 px
