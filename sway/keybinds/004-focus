# Regular focus change
bindsym $mod+z focus left ; focus up
bindsym $mod+x focus right ; focus down

# Page up/Down focus change
bindsym $mod+Prior focus left ; focus up
bindsym $mod+Next focus right ; focus down

# Alt Tab based focus change
bindsym Alt+Tab focus right ; focus down
bindsym Alt+Shift+Tab focus left ; focus up

# Fullscreen focus change
bindsym $mod+Tab fullscreen disable ; focus right ; focus down ; fullscreen enable
