bindn = Alt, Tab, cyclenext
# movefocus, r
			
# move focus to left
bindn = $mod, Z, movefocus, l
bindn = $mod, Page_Up, changegroupactive, b
bindn = Ctrl, Page_Up, changegroupactive, b
bindn = $mod, Tab, movefocus, l

# move focus to right
bindn = $mod, X, movefocus, r
bindn = $mod, Page_Down, changegroupactive, f
bindn = Ctrl, Page_Down, changegroupactive, f
bindn = $mod Shift, Tab, movefocus,r 


